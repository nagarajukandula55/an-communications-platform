# ==========================================================
# ACP Environment Configuration
# ==========================================================

# ----------------------------------------------------------
# Project
# ----------------------------------------------------------

NODE_ENV=development
APP_NAME=AN Communications Platform
APP_ENV=development

# ----------------------------------------------------------
# API
# ----------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=3000

# ----------------------------------------------------------
# Dashboard
# ----------------------------------------------------------

DASHBOARD_PORT=3001

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=acp
POSTGRES_USER=acp
POSTGRES_PASSWORD=acp

DATABASE_URL=postgresql://acp:acp@localhost:5432/acp

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------
# MinIO
# ----------------------------------------------------------

MINIO_ROOT_USER=acp
MINIO_ROOT_PASSWORD=acp123456

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----------------------------------------------------------
# JWT
# ----------------------------------------------------------

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------

LOG_LEVEL=debug

# ----------------------------------------------------------
# Queue
# ----------------------------------------------------------

QUEUE_PREFIX=acp

# ----------------------------------------------------------
# Timezone
# ----------------------------------------------------------

TZ=UTC
