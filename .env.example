# ==========================================================
# ACP Environment Configuration
# ==========================================================

# ----------------------------------------------------------
# Project
# ----------------------------------------------------------

NODE_ENV=development
APP_NAME=AN Communications Platform
APP_ENV=development

# ----------------------------------------------------------
# API
# ----------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=3000

# ----------------------------------------------------------
# ANgroup integration
# ----------------------------------------------------------

# ANgroup's base URL - used both for SSO (apps/api/src/main.ts's SsoClient,
# see packages/sso-client) and for ANu issue reporting (below). Unset in
# local dev/tests - SSO enforcement and ANu reporting are both no-ops
# without it, per each package's own doc comments.
ANGROUP_SSO_URL=

# Same ANgroup base URL, used by @acp/anu-report's AnuReportClient
# (wired into the messaging dead-letter queue) to report permanently-failed
# messages to ANgroup's ANu Issues & Reports inbox. Usually the same value
# as ANGROUP_SSO_URL - kept as a separate var since a deployment could
# reasonably point ANu reporting at a different ANgroup environment than
# the one it authenticates users against.
ANGROUP_API_URL=

# Must match ANgroup's own ANU_SERVICE_KEY env var exactly - this is what
# lets ACP (a backend service with no human session) authenticate to
# POST /api/anu/issues, which normally requires a signed-in user.
ANU_SERVICE_KEY=

# ----------------------------------------------------------
# Dashboard
# ----------------------------------------------------------

DASHBOARD_PORT=3001

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=acp
POSTGRES_USER=acp
POSTGRES_PASSWORD=acp

DATABASE_URL=postgresql://acp:acp@localhost:5432/acp

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------
# MinIO
# ----------------------------------------------------------

MINIO_ROOT_USER=acp
MINIO_ROOT_PASSWORD=acp123456

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----------------------------------------------------------
# JWT
# ----------------------------------------------------------

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------

LOG_LEVEL=debug

# ----------------------------------------------------------
# Queue
# ----------------------------------------------------------

QUEUE_PREFIX=acp

# ----------------------------------------------------------
# Timezone
# ----------------------------------------------------------

TZ=UTC
