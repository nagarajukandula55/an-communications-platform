{
  "$schema": "https://json.schemastore.org/tsconfig",

  "compilerOptions": {
    /* =========================
       Language
       ========================= */

    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* =========================
       Emit
       ========================= */

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,

    /* =========================
       Interop
       ========================= */

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* =========================
       Type Safety
       ========================= */

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "useUnknownInCatchVariables": true,

    /* =========================
       Imports
       ========================= */

    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    /* =========================
       Build
       ========================= */

    "incremental": true,
    "composite": true,

    /* =========================
       Performance
       ========================= */

    "skipLibCheck": true,

    /* =========================
       Paths
       ========================= */

    "baseUrl": ".",

    "paths": {
      "@acp/config": [
        "packages/config/src"
      ],
      "@acp/logger": [
        "packages/logger/src"
      ],
      "@acp/database": [
        "packages/database/src"
      ],
      "@acp/events": [
        "packages/events/src"
      ],
      "@acp/cache": [
        "packages/cache/src"
      ],
      "@acp/auth": [
        "packages/auth/src"
      ],
      "@acp/messaging": [
        "packages/messaging/src"
      ],
      "@acp/devices": [
        "packages/devices/src"
      ],
      "@acp/sms-transport": [
        "packages/sms-transport/src"
      ],
      "@acp/sso-client": [
        "packages/sso-client/src"
      ],
      "@acp/analytics": [
        "packages/analytics/src"
      ],
      "@acp/integrations": [
        "packages/integrations/src"
      ],
      "@acp/email-transport": [
        "packages/email-transport/src"
      ],
      "@acp/push-transport": [
        "packages/push-transport/src"
      ],
      "@acp/whatsapp-transport": [
        "packages/whatsapp-transport/src"
      ],
      "@acp/voice-transport": [
        "packages/voice-transport/src"
      ],
      "@acp/webhooks": [
        "packages/webhooks/src"
      ],
      "@acp/cli": [
        "packages/cli/src"
      ],
      "@acp/types": [
        "packages/types/src"
      ],
      "@acp/shared": [
        "packages/shared/src"
      ],
      "@acp/sdk": [
        "packages/sdk/src"
      ]
    }
  },

  "exclude": [
    "node_modules",
    "dist",
    ".next",
    "coverage"
  ]
}
